###############################################################
# LÉGION OSINT — .gitignore ULTIME (Termux / Android / Python)
# Optimisé pour environnements mobiles, OSINT, BlueTeam, scripts
###############################################################

############################
# ─── FICHIERS TEMPORAIRES ─
############################
*.log
*.tmp
*.bak
*.swp
*.lock
*.pid
*.cache
*.temp
tmp/
temp/

#################################
# ─── HISTORIQUES / SESSIONS ───
#################################
.bash_history
.zsh_history
.history
.session
*.session

###############################
# ─── PYTHON / VENV / BUILD ───
###############################
env/
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
build/
dist/
*.egg-info/

###################################
# ─── NODE / NPM / YARN (option) ─
###################################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

#################################
# ─── CLÉS / SECRETS / CONFIG ───
#################################
*.key
*.pem
*.crt
*.p12
*.der
*.jks
secrets.*
config.local.*
.env
.env.*
credentials.json
*.token
*.auth

#################################
# ─── TERMUX / ANDROID SYSTEM ───
#################################
.cache/
.termux/tasker/
.termux/boot/
.termux/shell/
.termux/colors.properties
.termux/font.ttf
termux.properties
*.properties

########################################
# ─── ÉDITEURS / IDE / CONFIG LOCALE ───
########################################
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

###################################
# ─── ARCHIVES / PACKAGES LOURDS ───
###################################
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

#########################################
# ─── OSINT / MOBILE FORENSICS / ANDROID ─
#########################################
*.apk
*.apks
*.aab
*.odex
*.vdex
*.dex
*.obb
*.img
*.bin
*.iso
*.qcow2
*.vmdk

###################################
# ─── RÉSEAU / CYBER / BLUE TEAM ───
###################################
*.pcap
*.pcapng
*.dump
*.cap
*.har
*.jsonl

#########################################
# ─── OUTPUTS INTERNES LÉGION OSINT ────
#########################################
logs/
output/
reports/
captures/
exports/
scans/
results/

#########################################
# ─── SCRIPTS / EXECUTABLES NON TRACKÉS ─
#########################################
*.exe
*.dll
*.so
*.o
*.out
*.class

#########################################
# ─── IMAGES / MÉDIAS NON ESSENTIELS ────
#########################################
*.jpg
*.jpeg
*.png
*.gif
*.bmp
*.svg
*.webp
*.mp4
*.mkv
*.mov
*.avi
*.mp3
*.wav

#########################################
# ─── DOCUMENTS LOURDS / NON TRACKÉS ────
#########################################
*.pdf
*.doc
*.docx
*.xls
*.xlsx
*.ppt
*.pptx

###############################################################
# FIN — Version ultime optimisée pour Termux / Android / OSINT
###############################################################
